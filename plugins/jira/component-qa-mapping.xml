<?xml version="1.0" encoding="UTF-8"?>
<!--
  Component-to-QA Contact Mapping for JIRA Plugin

  This file maps JIRA component names to their default QA contact owners.
  Used by the /jira:update-qa-contact command in dashboard and bugs modes.

  Usage:
    - Dashboard mode: /jira:update-qa-contact with dashboard parameter
    - Bug list mode: /jira:update-qa-contact with bugs parameter

  To customize:
    1. Replace placeholder emails (aaaa@, bbbb@, etc.) with actual QA contacts
    2. Add/remove component entries as needed
    3. Component names must match JIRA component field exactly (case-sensitive)
    4. Use email addresses for unambiguous user identification

  Example:
    <component name="Installer">
      <default-qa>alice@redhat.com</default-qa>
    </component>
-->
<component-qa-mapping>
  <!-- Core Components - Real QA Contacts (Alphabetically sorted) -->
  <component name="apiserver-auth">
    <default-qa>ksiddiqui@redhat.com</default-qa>
  </component>
