@startuml analyze-payload-flowchart
!theme plain
skinparam backgroundColor #FEFEFE
skinparam ActivityBackgroundColor #E8F4FD
skinparam ActivityBorderColor #1A73E8
skinparam ActivityDiamondBackgroundColor #FEF7E0
skinparam ActivityDiamondBorderColor #E37400
skinparam ArrowColor #333333
skinparam NoteBorderColor #5F6368
skinparam NoteBackgroundColor #F8F9FA
skinparam PartitionBorderColor #1A73E8
skinparam ActivityFontSize 13
skinparam defaultFontName "Segoe UI"

title Analyze Payload Flow\n/ci:analyze-payload

start

partition "Step 1: Parse Arguments" {
  :Parse payload tag from argument;
  note right
    Extract from tag:
    - version (e.g. 4.22)
    - stream (e.g. nightly)
    - architecture (amd64, arm64, ...)
    - --lookback N (default: 10)
  end note
}

partition "Step 2: Fetch Recent Payloads" {
  :Run fetch_payloads.py
  (limit = lookback * 2);
  :Find target payload in list;

  if (Payload phase?) then (Accepted)
    :Report "Payload accepted,
    no analysis needed";
    stop
  elseif (Rejected) then
    :Extract ALL failed blocking
    job names + Prow URLs;
  else (Ready / In-Progress)
    :Extract blocking jobs that
    have already **failed**;
    note right
      Partial analysis:
      payload still running
    end note
  endif
}

partition "Step 3: Build Failure History (Lookback)" {
  :Walk backwards through
  consecutive rejected payloads;

  while (More previous payloads\nand within lookback limit?) is (yes)
    :Check if each failing job
    also failed in previous payload;
    if (Previous payload Accepted\nor job was passing?) then (yes)
      :Found **originating payload**
      for this job;
    else (no)
      :Extend streak, continue walking back;
    endif
  endwhile (no)

  :Record per-job:
  - streak_length
  - originating_payload
  - is_new_failure;
}

partition "Step 4: Fetch New PRs in Originating Payloads" {
  :Collect unique originating
  payload tags;
  :Run fetch_new_prs_in_payload.py
  for each originating payload;
  :Store suspect PRs keyed
  by originating payload;
}

partition "Step 5: Investigate Failed Jobs (Parallel)" {
  fork
    :Subagent: Analyze Job 1;
  fork again
    :Subagent: Analyze Job 2;
  fork again
    :Subagent: Analyze Job N...;
  end fork

  note right
    Each subagent:
    1. Check JUnit for failure type
    2. Install failure -> use
       prow-job-analyze-install-failure
       (+ metal skill for metal jobs)
    3. Test failure -> use
       prow-job-analyze-test-failure
    4. Aggregated jobs -> extract
       underlying job name from
       junit-aggregated.xml
    5. Return ANALYSIS_RESULT block
  end note
}

partition "Step 6: Correlate & Identify Reverts" {
  :6.1: Score each (job, suspect PR) pair
  using weighted confidence rubric;
  note right
    Rubric weights:
    - Temporal match: +30
    - Component match: +10 to +30
    - Error message match: +30
    - Single suspect: +10
    Max score: 100
  end note

  :6.2: Identify revert candidates
  (rubric score >= 85);

  if (Revert candidates found?) then (yes)
    :6.3: Check if revert PRs
    already exist (gh pr list);

    if (Revert already merged?) then (yes)
      :Note: "Already reverted,
      fix expected in next payload";
    elseif (Revert PR open?) then
      :Note: "Revert in progress,
      help expedite merge";
    else (no existing revert)
      :Mark as actionable
      revert candidate;
    endif
  else (no)
    :No high-confidence
    revert candidates;
  endif
}

partition "Step 7: Generate HTML Report" {
  :7.1: Header & Executive Summary
  (total jobs, pass/fail, streak);

  :7.2: Blocking Jobs Summary Table
  (all jobs, status, streak, origin);

  if (Revert candidates exist?) then (yes)
    :7.4: Recommended Reverts table
    + copy-paste revert instructions;
  else (no)
    :7.4: "No high-confidence
    revert candidates" note;
  endif

  :7.3: Failed Job Details
  (collapsible per-job sections with
  analysis, suspect PRs, Prow links);

  :7.5: Embed all CSS styles;
}

partition "Step 8: Generate JSON Data File" {
  :Build flat table: one row per
  (failed job, revert candidate) pair;
  note right
    - All values as strings
    - Payload stats denormalized
    - Revert fields empty if none
    - Multiple rows per job if
      2+ revert candidates
    - Filename: *-autodl.json
  end note
  :Write payload-analysis-<tag>-autodl.json;
}

partition "Step 9: Save & Present" {
  :Save HTML report to CWD
  payload-analysis-<tag>-summary.html;
  :Save JSON data file to CWD
  payload-analysis-<tag>-autodl.json;
  :Present file paths + brief
  text summary to user;
}

stop

legend right
  |= Symbol |= Meaning |
  | Diamond | Decision point |
  | Fork/Join | Parallel execution |
  | Partition | Major step |
endlegend

@enduml
