@startuml payload-agent-flowchart
!theme plain
skinparam backgroundColor #FEFEFE
skinparam ActivityBackgroundColor #E8F4FD
skinparam ActivityBorderColor #1A73E8
skinparam ActivityDiamondBackgroundColor #FEF7E0
skinparam ActivityDiamondBorderColor #E37400
skinparam ArrowColor #333333
skinparam NoteBorderColor #5F6368
skinparam NoteBackgroundColor #F8F9FA
skinparam PartitionBorderColor #1A73E8
skinparam ActivityFontSize 13
skinparam defaultFontName "Segoe UI"

title Payload Agent Flow\n/ci:payload-agent

start

partition "Step 1: Parse Arguments & Detect Resume" {
  :Parse payload tag from argument;
  note right
    Extract from tag:
    - version (e.g. 4.22)
    - stream (e.g. nightly)
    - architecture (amd64, arm64, ...)
  end note

  if (suspects YAML exists?) then (yes)
    if (any suspect has\naction_status: pending?) then (yes)
      :Jump to Step 5
      (Experiment Phase 2);
      detach
    else (no)
      :Jump to Step 3
      (Read Suspects & Classify);
      detach
    endif
  else (no)
  endif
}

partition "Step 2: Run Analysis" {
  :Execute analyze-payload
  Steps 1-6 (incl. 6.4 suspects YAML);
  note right
    Writes suspects YAML
    to CWD
  end note
}

partition "Step 3: Read Suspects & Classify" {
  :Read suspects YAML;

  :Classify suspects into tiers;
  note right
    HIGH: >= 85
    MEDIUM: 60-84
    LOW: < 60
  end note

  :Filter out suspects with
  existing merged/open reverts;
}

partition "Step 4: Decision & Dispatch" {
  if (Any HIGH confidence\nsuspects?) then (yes)
    :Dispatch to
    **stage-payload-reverts**;
    note right
      For each HIGH suspect:
      1. Create TRT JIRA Bug
      2. Open Revert PR
      3. Trigger payload jobs
      4. Update suspects YAML
    end note
  else (no)
  endif

  if (Any MEDIUM confidence\nsuspects?) then (yes)
    :Dispatch to
    **payload-experimental-reverts**
    Phase 1;
  else (no)
  endif
}

if (Experiment Phase 1\nwas initiated?) then (yes)

  partition "Experiment Phase 1: Set Up Experiments (Parallel)" {
    fork
      :Subagent: Experiment Suspect A;
    fork again
      :Subagent: Experiment Suspect B...;
    end fork

    note right
      Each subagent:
      1. Check for merge conflicts
      2. Open **draft** revert PR
      3. Trigger payload jobs
      4. Collect pr-payload-tests URL
    end note

    :Update suspects YAML with
    action_status: pending;
  }

else (no)
endif

' Rejoin from resume path
if (Suspects with\naction_status: pending?) then (resume)

  partition "Step 5: Experiment Phase 2 (Collect Results)" {
    :Read suspects YAML
    (pending experiments);

    while (More pending experiments?) is (yes)
      :Fetch payload_test_url,
      check for AllJobsFinished;

      if (Jobs finished?) then (yes)
        if (Payload jobs PASS\nwith revert?) then (yes — confirmed cause)
          :Create TRT JIRA Bug;
          :Promote draft PR to real PR
          (gh pr ready);
          :Record: action_status = passed;
        else (no — PR is innocent)
          :Post explanation comment;
          :Close draft PR
          (gh pr close);
          :Record: action_status = failed;
        endif
      else (not finished)
        :Record: action_status = inconclusive;
      endif
    endwhile (no)

    :Update suspects YAML
    with results;
  }

else (no experiments)
endif

partition "Step 6: Generate Report & Artifacts" {
  :Run analyze-payload Steps 7-9
  (HTML report + autodl.json);

  if (HIGH reverts staged?) then (yes)
    :Add "Staged Reverts" table
    (JIRA, revert PR, payload jobs);
  else (no)
  endif

  if (Experiment Phase 1 only?) then (yes)
    :Add "Experiments In Progress" section
    (draft PRs, payload test URLs);
  elseif (Experiment Phase 2 done?) then
    :Add "Experiment Results" section
    (confirmed / innocent verdicts);
  else (no experiments)
  endif
}

partition "Step 7: Exit" {
  if (Experiments pending?) then (yes)
    :Print suspects YAML path;
    :Print resume instructions:
    run /ci:payload-agent <tag>
    again from this directory;
  else (no)
    :Print report file paths
    + brief summary;
  endif
}

stop

legend right
  |= Tier |= Score |= Action |
  | HIGH | >= 85 | Stage revert (JIRA + PR + jobs) |
  | MEDIUM | 60-84 | Experiment (draft PR + jobs) |
  | LOW | < 60 | Report only |
endlegend

@enduml
