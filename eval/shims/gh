#!/bin/bash
# gh shim — serves cached GitHub API responses for eval testing.
# When EVAL_ARCHIVES_DIR is set, intercepts gh commands and serves
# from cached files or returns empty results.

CACHE="${EVAL_ARCHIVES_DIR}"

SHIM_LOG="${EVAL_ARCHIVES_DIR:+${EVAL_ARCHIVES_DIR}/.shim-gh.log}"
log_shim() { [[ -n "$SHIM_LOG" ]] && echo "[$(date -u +%H:%M:%S)] gh $*" >> "$SHIM_LOG"; }

# Find real gh (excluding this shim)
find_real_gh() {
    local self
    self="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
    local IFS=:
    for dir in $PATH; do
        local candidate="$dir/gh"
        if [[ -x "$candidate" && "$(realpath "$candidate" 2>/dev/null)" != "$(realpath "$self" 2>/dev/null)" ]]; then
            echo "$candidate"
            return
        fi
    done
    echo "/usr/bin/gh"
}

REAL_GH="$(find_real_gh)"

if [[ -z "$CACHE" ]]; then
    exec "$REAL_GH" "$@"
fi

# Look up cached PR data: gh-cache/{org}/{repo}/{pr_number}.json
lookup_pr_cache() {
    local pr_num="$1"
    local repo="$2"
    [[ -z "$pr_num" || -z "$repo" ]] && return 1

    for subdir in "$CACHE"/*/gh-cache/"$repo"/; do
        [[ -d "$subdir" ]] || continue
        local cache_file="${subdir}${pr_num}.json"
        if [[ -f "$cache_file" ]]; then
            echo "$cache_file"
            return 0
        fi
    done
    return 1
}

case "$1" in
    pr)
        case "$2" in
            list)
                log_shim "INTERCEPT pr list → []"
                echo "[]"
                exit 0
                ;;
            view)
                # Try to find cached response
                # Parse: gh pr view <number> --repo <org/repo> [--json ...]
                pr_num="" repo=""
                shift 2
                while [[ $# -gt 0 ]]; do
                    case "$1" in
                        --repo) repo="$2"; shift 2 ;;
                        --json|--jq) shift 2 ;;
                        --*) shift ;;
                        *) [[ -z "$pr_num" ]] && pr_num="$1"; shift ;;
                    esac
                done

                cache_file="$(lookup_pr_cache "$pr_num" "$repo")"
                if [[ $? -eq 0 && -f "$cache_file" ]]; then
                    log_shim "INTERCEPT pr view $repo#$pr_num → $cache_file"
                    cat "$cache_file"
                    exit 0
                fi

                log_shim "MISS pr view $repo#$pr_num → {}"
                echo "{}"
                exit 0
                ;;
            *)
                log_shim "INTERCEPT pr $2 → {}"
                echo "{}"
                exit 0
                ;;
        esac
        ;;
    api)
        log_shim "INTERCEPT api $* → {}"
        echo "{}"
        exit 0
        ;;
    *)
        log_shim "BLOCKED $*"
        echo "{}"
        exit 0
        ;;
esac
